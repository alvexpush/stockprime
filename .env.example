# Copy these into your hosting environment or local shell.
FINNHUB_API_KEY=your_finnhub_api_key
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key
RESEND_API_KEY=your_resend_api_key
RESET_FROM_EMAIL=StockPrime <support@example.com>
AUTH_FROM_EMAIL=StockPrime <security@example.com>

# Zoho Mail OAuth (recommended transactional email provider)
# Scope: ZohoMail.messages.CREATE,ZohoMail.accounts.READ
EMAIL_PROVIDER=zoho
ZOHO_CLIENT_ID=your_zoho_client_id
ZOHO_CLIENT_SECRET=your_rotated_zoho_client_secret
ZOHO_REFRESH_TOKEN=your_zoho_refresh_token
# Optional: discovered automatically using ZohoMail.accounts.READ when omitted
ZOHO_ACCOUNT_ID=your_numeric_zoho_mail_account_id
ZOHO_FROM_EMAIL=security@yourdomain.com
# Change both hosts for your Zoho data center, e.g. .eu, .in, .com.au, .jp, .ca, .sa
ZOHO_ACCOUNTS_URL=https://accounts.zoho.com
ZOHO_MAIL_API_URL=https://mail.zoho.com/api
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_this_password
SESSION_DAYS=7
PORT=3000
